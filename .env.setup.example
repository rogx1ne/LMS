# ============================================
# LMS Setup Configuration
# ============================================
# This file contains database credentials needed for the LMS setup wizard.
# 
# IMPORTANT: Before running setup.exe or setup.sh, edit this file with your
# Oracle SYSTEM credentials, then rename it to .env.setup (remove .example)
#
# The setup wizard will read these environment variables and use them to:
# 1. Connect to Oracle as SYSTEM user
# 2. Reset the PRJ2531H user (drop and recreate)
# 3. Initialize the database schema
#
# After setup completes, you can safely delete this file.

# Oracle connection details
LMS_DB_URL=jdbc:oracle:thin:@localhost:1521:xe

# Oracle SYSTEM user credentials (required for database initialization)
# Change these to match YOUR Oracle installation
LMS_SYSTEM_USER=system
LMS_SYSTEM_PASSWORD=oracle

# PRJ2531H user credentials (default, used by the application)
# These will be used to create the PRJ2531H user
LMS_DB_USER=PRJ2531H
LMS_DB_PASSWORD=PRJ2531H

# ============================================
# QUICK START GUIDE
# ============================================
# 
# Linux/Mac:
#   1. Edit this file with your SYSTEM credentials
#   2. Rename: mv .env.setup.example .env.setup
#   3. Run setup: export $(cat .env.setup) && ./setup-wizard.sh
#
# Windows:
#   1. Edit this file with your SYSTEM credentials
#   2. Rename: rename .env.setup.example .env.setup
#   3. Create lms-setup.bat in same directory, then double-click it
#      (The setup wizard will automatically read .env.setup)
#
# ============================================
# TROUBLESHOOTING
# ============================================
#
# If you see: "Could not connect as SYSTEM to reset PRJ2531H user"
#   → Verify LMS_SYSTEM_PASSWORD is correct
#   → Verify Oracle is running at LMS_DB_URL
#   → Check Oracle listener status
#
# If you don't know the SYSTEM password:
#   → Ask your Oracle DBA for the SYSTEM user password
#   → Or contact your IT department
#   → The system/oracle default only works on development machines
#
